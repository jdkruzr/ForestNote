<?xml version="1.0" encoding="utf-8"?>
<!-- Library search dialog: a query input at the top, status text below, and a scrollable
     RecyclerView of result rows. Hosted in an AlertDialog by SearchDialog.kt. Height is
     fixed so the dialog stays modal-sized on the AiPaper Mini; rows are smaller than the
     Library's grid cards (the icon + title + snippet pattern, ~56dp tall) so a useful
     number of hits fit at once. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/search_root"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/search_input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/search_query"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search notebooks, text, OCR…"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_dark"
            android:textSize="15sp"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/search_submit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_search"
            android:background="?attr/selectableItemBackground"
            android:scaleType="fitCenter"
            android:contentDescription="Run search" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black" />

    <TextView
        android:id="@+id/search_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="Type at least 2 characters to search."
        android:textColor="@color/gray_dark"
        android:textSize="12sp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="4dp"
        android:visibility="gone" />
</LinearLayout>
