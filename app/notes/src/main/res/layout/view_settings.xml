<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen Settings overlay (library-and-tools B2). Opaque white + clickable so
     it covers the editor and swallows touches. Header (Back + title) over a 1px rule,
     then a scrolling body of Section headers + Field rows. Pitch radio buttons are
     added in code from SettingsFormLogic.pitchPresetsMm. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <!-- Header: Back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/btn_settings_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←  Library"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Settings"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Spacer to balance the back button so the title stays centred -->
        <View
            android:layout_width="72dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!-- ===== Editor ===== -->
            <TextView style="@style/SettingsSection" android:text="Editor" />

            <TextView style="@style/SettingsLabel" android:text="Default page template" />

            <RadioGroup
                android:id="@+id/rg_template"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rb_template_blank" style="@style/SettingsRadio" android:text="Blank" />
                <RadioButton android:id="@+id/rb_template_dot" style="@style/SettingsRadio" android:text="Dot" />
                <RadioButton android:id="@+id/rb_template_ruled" style="@style/SettingsRadio" android:text="Ruled" />
                <RadioButton android:id="@+id/rb_template_grid" style="@style/SettingsRadio" android:text="Grid" />
            </RadioGroup>

            <!-- Pitch row: shown only when template != Blank; buttons added in code. -->
            <LinearLayout
                android:id="@+id/row_pitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/SettingsLabel" android:text="Pitch" />

                <RadioGroup
                    android:id="@+id/rg_pitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- ===== Startup ===== -->
            <TextView style="@style/SettingsSection" android:text="Startup" />

            <TextView style="@style/SettingsLabel" android:text="When the app opens" />

            <RadioGroup
                android:id="@+id/rg_start_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/rb_start_last" style="@style/SettingsRadio" android:text="Last notebook" />
                <RadioButton android:id="@+id/rb_start_library" style="@style/SettingsRadio" android:text="Library" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/check_prefill_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:text="Pre-fill new-notebook names with timestamp (YYYYMMDD_HHMMSS)" />

            <!-- ===== Sync ===== -->
            <TextView style="@style/SettingsSection" android:text="Sync" />

            <TextView style="@style/SettingsLabel" android:text="Sync server URL" />
            <EditText
                android:id="@+id/input_sync_url"
                style="@style/SettingsInput"
                android:hint="https://…"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Username" />
            <EditText
                android:id="@+id/input_sync_username"
                style="@style/SettingsInput"
                android:hint="username"
                android:inputType="text"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Password" />
            <EditText
                android:id="@+id/input_sync_password"
                style="@style/SettingsInput"
                android:hint="password"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Auto-sync every N minutes (0 = off)" />
            <EditText
                android:id="@+id/input_sync_interval"
                style="@style/SettingsInput"
                android:hint="15"
                android:inputType="number"
                android:imeOptions="actionDone" />

            <!-- ===== AI endpoints ===== -->
            <TextView style="@style/SettingsSection" android:text="AI endpoints" />

            <TextView style="@style/SettingsLabel" android:text="Selection recognition URL (leave blank for on-device)" />
            <EditText
                android:id="@+id/input_selection_url"
                style="@style/SettingsInput"
                android:hint="https://…"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Full-text transcription URL" />
            <EditText
                android:id="@+id/input_fulltext_url"
                style="@style/SettingsInput"
                android:hint="https://…"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Chat about my notes URL" />
            <EditText
                android:id="@+id/input_chat_url"
                style="@style/SettingsInput"
                android:hint="https://…"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <!-- ===== Recognition models ===== -->
            <!-- On-device handwriting recognition (MLKit Digital Ink). The container is
                 populated programmatically by SettingsView with a row per installed
                 language plus a Delete affordance. The Download button opens an
                 AlertDialog with a language picker. -->
            <TextView style="@style/SettingsSection" android:text="Recognition models" />

            <TextView style="@style/SettingsLabel" android:text="Installed languages" />
            <LinearLayout
                android:id="@+id/container_recognition_models"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btn_download_recognition_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download model…"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <!-- ===== Calendar (CalDAV tasks) =====
                 Configures the lasso-recognize → VTODO PUT flow. The pill + task sheet only
                 appear after recognition when all three fields below are non-blank.
                 Credentials are stored in EncryptedSharedPreferences via SecureCredentialsStore,
                 NOT in the Settings JSON blob (which previously held only the URL). -->
            <TextView style="@style/SettingsSection" android:text="Calendar (CalDAV tasks)" />

            <TextView style="@style/SettingsLabel" android:text="Collection URL" />
            <EditText
                android:id="@+id/input_caldav_url"
                style="@style/SettingsInput"
                android:hint="https://nc.example.com/remote.php/dav/calendars/USER/tasks/"
                android:inputType="textUri"
                android:imeOptions="actionDone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_dark"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:text="iCloud: caldav.icloud.com (use an app-specific password)" />

            <TextView style="@style/SettingsLabel" android:text="Username" />
            <EditText
                android:id="@+id/input_caldav_username"
                style="@style/SettingsInput"
                android:hint="username"
                android:inputType="text"
                android:imeOptions="actionDone" />

            <TextView style="@style/SettingsLabel" android:text="Password" />
            <EditText
                android:id="@+id/input_caldav_password"
                style="@style/SettingsInput"
                android:hint="password"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />

            <Button
                android:id="@+id/btn_caldav_test"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Test connection"
                android:layout_marginTop="8dp" />

            <!-- Offline-queue UI: populated by SettingsView from
                 NotebookStore.listCalDavOutbox + CalDavOutboxDrainer.status. Each row
                 is built programmatically with Cancel/Retry/Delete affordances. Hidden
                 entirely when the queue is empty. -->
            <TextView
                android:id="@+id/label_caldav_queued"
                style="@style/SettingsLabel"
                android:text="Queued tasks"
                android:paddingTop="16dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/container_caldav_queued"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btn_caldav_drain_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drain now"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- ===== Recycle Bin ===== -->
            <TextView style="@style/SettingsSection" android:text="Recycle Bin" />

            <TextView style="@style/SettingsLabel" android:text="Auto-empty after N days (0 = never)" />
            <EditText
                android:id="@+id/input_bin_retention_days"
                style="@style/SettingsInput"
                android:hint="0"
                android:inputType="number"
                android:imeOptions="actionDone" />

            <!-- ===== Debug ===== -->
            <TextView style="@style/SettingsSection" android:text="Debug" />

            <CheckBox
                android:id="@+id/check_debug_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:text="Write debug logs to /sdcard/ForestNote" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
