<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen Library overlay (library-and-tools C3a). Opaque white + clickable so it
     covers the editor and swallows touches (mirrors view_settings.xml). A 30dp header
     row (matching the navbar height) over a 1px rule, then a RecyclerView card grid.
     Header cells, left→right: Settings, back chevron (gone until C5), breadcrumb, item
     count, spacer, Select / +Folder / Recycle Bin (greyed until later phases), +Notebook
     (active). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/library_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/library_header"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btn_library_settings"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />

        <ImageButton
            android:id="@+id/btn_library_back"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Up one level"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_breadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Library"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_item_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/gray_dark"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_library_select"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_select"
            android:contentDescription="Select"
            android:enabled="false"
            android:alpha="0.3" />

        <ImageButton
            android:id="@+id/btn_library_add_folder"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_create_folder"
            android:contentDescription="New folder"
            android:enabled="false"
            android:alpha="0.3" />

        <ImageButton
            android:id="@+id/btn_library_recycle_bin"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_delete"
            android:contentDescription="Recycle bin"
            android:enabled="false"
            android:alpha="0.3" />

        <ImageButton
            android:id="@+id/btn_library_add_notebook"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="@color/white"
            android:src="@drawable/ic_add"
            android:contentDescription="New notebook" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/library_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />
</LinearLayout>
