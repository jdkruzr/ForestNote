<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen Library overlay (library-and-tools C3a–C5). Opaque white + clickable so it
     covers the editor and swallows touches (mirrors view_settings.xml). A header row (icon+
     caption cells, matching the editor toolbar convention) over a 1px rule, then a
     RecyclerView card grid. Header cells, left→right: Settings, Up (back, gone until in a
     folder), breadcrumb, count, then Select / Recycle (greyed until later phases) + Folder /
     Notebook (active). Each action is a vertical cell (the cell is the hitbox; the inner
     ImageButton is non-clickable so taps fall through), the same pattern as toolbar.xml. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/library_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/library_header"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white">

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/btn_library_settings"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Settings"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_settings"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Sync now: caption doubles as the sync status line (Phase 5). A plain action (no ▾) —
             tapping runs a manual sync; the caption reflects idle/syncing/synced/error. -->
        <LinearLayout
            android:id="@+id/btn_library_sync"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Sync now"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_refresh"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_library_sync_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Up (back one level; shown only inside a folder) -->
        <LinearLayout
            android:id="@+id/btn_library_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Up one level"
            android:background="?attr/selectableItemBackground"
            android:visibility="gone">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_arrow_left"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Up"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/breadcrumb_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/text_item_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="8dp"
            android:text=""
            android:textColor="@color/gray_dark"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Select (multi-select; greyed until a later phase) -->
        <LinearLayout
            android:id="@+id/btn_library_select"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:contentDescription="Select"
            android:enabled="false"
            android:alpha="0.3">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_select"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_library_select_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Recycle Bin: visible but disabled (greyed, non-clickable) until phase E3 wires the
             actual bin view. D3 deletes are hard deletes — soft delete + the bin land in area E. -->
        <LinearLayout
            android:id="@+id/btn_library_recycle_bin"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:contentDescription="Recycle bin"
            android:enabled="false"
            android:alpha="0.3">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_delete"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_recycle_bin_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recycle"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- New folder -->
        <LinearLayout
            android:id="@+id/btn_library_add_folder"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="New folder"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_create_folder"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Folder ▾"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- New notebook -->
        <LinearLayout
            android:id="@+id/btn_library_add_notebook"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="New notebook"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_add"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notebook ▾"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/library_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Select-mode bottom action bar (D1). In-flow (not a floating pill): the grid above is
         weighted, so it shrinks to make room and the last card row is never occluded. Hidden
         until Select mode is entered. White over a 1dp black top rule, mirroring the header. -->
    <View
        android:id="@+id/select_bar_rule"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/select_action_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_select_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_select_move"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Move"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_select_delete"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Delete"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_select_done"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Done"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>
