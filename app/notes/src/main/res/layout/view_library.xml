<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen Library overlay (library-and-tools C3a-C5). Opaque white + clickable so it
     covers the editor and swallows touches (mirrors view_settings.xml). Two compact header
     rows keep every action visible on narrow Boox screens: Library + global actions on top,
     then counts/breadcrumb + selection/create actions below. Each action is a vertical cell
     (the cell is the hitbox; the inner ImageButton is non-clickable so taps fall through),
     the same pattern as toolbar.xml. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/library_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/library_header"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white">

        <!-- Two-row header: this is row A (title + toolbar). The title sits flush left,
             toolbar cells flush right via the weight=1 spacer between them. The breadcrumb
             + counts + Up button live on their own row below (see library_breadcrumb_row)
             so they can grow without affecting the toolbar.
             The "Library" title doubles as a clickable home: tapping it from inside a
             folder navigates back to root (LibraryView wires the listener). -->
        <TextView
            android:id="@+id/text_library_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Library"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/btn_library_settings"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Settings"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_settings"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Sync now: caption doubles as the sync status line (Phase 5). A plain action (no ▾) —
             tapping runs a manual sync; the caption reflects idle/syncing/synced/error. -->
        <LinearLayout
            android:id="@+id/btn_library_sync"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Sync now"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_refresh"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_library_sync_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp"
                android:gravity="center_horizontal"
                android:minWidth="56dp" />
        </LinearLayout>

        <!-- Search: opens a modal dialog over the Library that searches notebook + folder
             names, text-box content, and per-page OCR text (server-authored). A direct
             action (no ▾) — taps the magnifier to open the dialog. -->
        <LinearLayout
            android:id="@+id/btn_library_search"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Search"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_search"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Row B: library-wide counts, then a thin divider, then the folder-path breadcrumb
         and the Library management actions. On narrow screens the breadcrumb gives way
         before any action falls off the right edge. -->
    <LinearLayout
        android:id="@+id/library_breadcrumb_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/white">

        <!-- Compact library-wide counts: two small icon+number pairs (notebook · folder),
             set from NotebookStore.libraryTotals. Now leftmost so it reads as the
             library-state header for the row. -->
        <LinearLayout
            android:id="@+id/library_counts"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_notebook"
                android:tint="@color/black"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/text_notebook_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:paddingEnd="10dp"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:maxLines="1" />
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_folder"
                android:tint="@color/black"
                android:importantForAccessibility="no" />
            <TextView
                android:id="@+id/text_folder_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Thin vertical divider separating the counts cluster from the breadcrumb area.
             Mirrors the rule between Search and Select in the toolbar row above. -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/black" />

        <!-- Up (back one level; shown only inside a folder, paired with the breadcrumb). -->
        <LinearLayout
            android:id="@+id/btn_library_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Up one level"
            android:background="?attr/selectableItemBackground"
            android:visibility="gone">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_arrow_left"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Up"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Breadcrumb itself. BreadcrumbView fills this:
               * At root: a dimmed italic placeholder ("Root") so the user can
                 see at a glance that this row is where folder paths appear.
               * In a folder: the path segments (no leading "Library" — the toolbar title
                 + Up button serve that role). -->
        <LinearLayout
            android:id="@+id/breadcrumb_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp" />

        <!-- Select (multi-select). -->
        <LinearLayout
            android:id="@+id/btn_library_select"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:contentDescription="Select"
            android:enabled="false"
            android:alpha="0.3">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_select"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_library_select_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- Recycle Bin. The count badge is filled in by LibraryView.reload(). -->
        <LinearLayout
            android:id="@+id/btn_library_recycle_bin"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:contentDescription="Recycle bin"
            android:enabled="false"
            android:alpha="0.3">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_delete"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:id="@+id/text_recycle_bin_caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recycle"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- New folder -->
        <LinearLayout
            android:id="@+id/btn_library_add_folder"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="New folder"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_create_folder"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Folder"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <!-- New notebook -->
        <LinearLayout
            android:id="@+id/btn_library_add_notebook"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="New notebook"
            android:background="?attr/selectableItemBackground">
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/ic_add"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:background="@null"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notebook"
                android:textSize="9sp"
                android:textColor="@color/black"
                android:maxLines="1"
                android:paddingBottom="2dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/library_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Select-mode bottom action bar (D1). In-flow (not a floating pill): the grid above is
         weighted, so it shrinks to make room and the last card row is never occluded. Hidden
         until Select mode is entered. White over a 1dp black top rule, mirroring the header. -->
    <View
        android:id="@+id/select_bar_rule"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/select_action_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_select_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_select_move"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Move"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_select_delete"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Delete"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btn_select_done"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Done"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>
</LinearLayout>
