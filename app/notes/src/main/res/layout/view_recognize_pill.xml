<?xml version="1.0" encoding="utf-8"?>
<!-- Floating pill shown after a lasso-recognize completes, when CalDAV is configured.
     Displays the recognized text and a single "Create task" action. Tapping outside
     (handled by the scrim) dismisses. Non-focusable so canvas continues to accept
     pen input under it (matches SelectionMenuView's discipline). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pill_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/white"
    android:padding="10dp"
    android:elevation="6dp"
    android:focusable="false"
    android:focusableInTouchMode="false">

    <!-- The (possibly ellipsized) recognized text. Width capped to prevent the pill
         from sprawling across the page; CalDavTaskSheetLogic.pillLabel handles the trim. -->
    <TextView
        android:id="@+id/pill_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="220dp"
        android:singleLine="true"
        android:ellipsize="end"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:paddingEnd="14dp"
        android:paddingStart="2dp" />

    <!-- 1px vertical rule mirroring SelectionMenuView's separator look. -->
    <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:background="@color/black" />

    <TextView
        android:id="@+id/btn_create_task"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create task"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:minWidth="80dp"
        android:gravity="center" />
</LinearLayout>
