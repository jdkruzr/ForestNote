<?xml version="1.0" encoding="utf-8"?>
<!-- Pixel eraser: a 2x2 checkerboard (erases by region / pixels). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- filled diagonal cells -->
    <path
        android:fillColor="#000000"
        android:pathData="M4,4 H12 V12 H4 Z" />
    <path
        android:fillColor="#000000"
        android:pathData="M12,12 H20 V20 H12 Z" />
    <!-- outer frame + center dividers so the empty cells read as a checkerboard -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#000000"
        android:strokeWidth="1.5"
        android:pathData="M4,4 H20 V20 H4 Z M12,4 V20 M4,12 H20" />
</vector>
