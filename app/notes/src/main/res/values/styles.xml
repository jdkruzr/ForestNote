<?xml version="1.0" encoding="utf-8"?>
<!-- Settings screen field styles (library-and-tools B2). Plain, high-contrast,
     e-ink friendly: black on white, generous tap targets, no elevation. -->
<resources>

    <style name="SettingsSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="SettingsLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/gray_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <style name="SettingsRadio">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <style name="SettingsInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_light</item>
        <item name="android:textSize">15sp</item>
        <item name="android:maxLines">1</item>
    </style>

</resources>
