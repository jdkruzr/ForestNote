<?xml version="1.0" encoding="utf-8"?>
<!--
  ForestNote launcher icon — foreground layer.
  108×108dp adaptive-icon canvas. The pine+pen mark is authored in a 256-unit
  design space (path coords 34-222 wide × 28-232 tall). We fit it inside the
  adaptive icon's 66×66dp safe zone (the 21-87 viewport range that survives
  any mask shape) by scaling 0.32 (≈ 65 × 65) and translating (13, 12) so the
  bounding box lands at ≈ (24, 21)-(84, 86) — comfortably inside the safe
  zone, so round/squircle masks no longer crop the tips of the tree.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="0.32"
        android:scaleY="0.32"
        android:translateX="13"
        android:translateY="12">
        <path
            android:fillColor="#000000"
            android:fillType="evenOdd"
            android:pathData="M128,28 L196,96 L168,96 L210,144 L176,144 L222,196 L142,196 L142,232 L114,232 L114,196 L34,196 L80,144 L46,144 L88,96 L60,96 Z M117,72 L139,72 L139,144 L128,164 L117,144 Z" />
    </group>
</vector>
